# Create a class for a Student
class Student:
    def __init__(self, name, age, reg_no, math, science, sst, cre):
        self.name = name
        self.age = age
        self.reg_no = reg_no
        self.math = math
        self.science = science
        self.sst = sst
        self.cre = cre

    # calculate total marks
    def total_marks(self):
        return self.math + self.science + self.sst + self.cre

    # calculate average marks
    def average_marks(self):
        return self.total_marks() / 4

    # Method to display student details
    def display(self):
        print("\n----- Student Report -----")
        print("Name:", self.name)
        print("Age:", self.age)
        print("Registration Number:", self.reg_no)
        print("Math:", self.math)
        print("Science:", self.science)
        print("SST:", self.sst)
        print("CRE:", self.cre)
        print("Total Marks:", self.total_marks())
        print("Average Marks:", self.average_marks())

# Collect data from the student 
name = input("Enter student name: ")
age = int(input("Enter student age: "))
reg_no = input("Enter registration number: ")
math = int(input("Enter Math marks: "))
science = int(input("Enter Science marks: "))
sst = int(input("Enter SST marks: "))
cre = int(input("Enter CRE marks: "))

# Create a student object
student1 = Student(name, age, reg_no, math, science, sst, cre)  
student1.display()
